# 复制此文件为 .env 并填入 API Key。推荐使用 ENVX（OpenAI 兼容）+ gpt-4o-mini。
# 不要提交 .env 到版本库

# ENVX（OpenAI 兼容，推荐）
ENVX_API_KEY=sk-your-envx-key
ENVX_BASE_URL=https://envx.build/v1
LLM_MODEL=gpt-4o-mini

# Kimi（月之暗面）
KIMI_API_KEY=sk-your-kimi-key

# 通义/千问（阿里云 DashScope，可选）
# DASHSCOPE_API_KEY=sk-ant-api03-xxx
# 自建或其它 OpenAI 兼容：LLM_API_KEY=key & DASHSCOPE_BASE_URL=https://xxx/v1
