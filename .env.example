# 复制此文件为 .env 并填入 API Key
# 不要提交 .env 到版本库

# OpenRouter（推荐）
# OPENROUTER_API_KEY=sk-or-v1-xxx
# OPENROUTER_MODEL=moonshotai/kimi-k2.5

# Kimi（月之暗面，可选）
# KIMI_API_KEY=sk-your-kimi-key
# KIMI_MODEL=moonshot-v1-8k

# 通义/千问（阿里云 DashScope，可选）
# DASHSCOPE_API_KEY=sk-ant-api03-xxx
# DASHSCOPE_MODEL=qwen-plus
# 自建或其它 OpenAI 兼容：LLM_API_KEY=key & DASHSCOPE_BASE_URL=https://xxx/v1

# Replicate（语音转写 openai/whisper）
REPLICATE_API_TOKEN=r8_your_replicate_token
